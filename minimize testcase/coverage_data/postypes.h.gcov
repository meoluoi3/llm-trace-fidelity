        -:   35:#ifndef _GLIBCXX_POSTYPES_H
        -:   36:#define _GLIBCXX_POSTYPES_H 1
        -:   37:
        -:   38:#ifdef _GLIBCXX_SYSHDR
        -:   39:#pragma GCC system_header
