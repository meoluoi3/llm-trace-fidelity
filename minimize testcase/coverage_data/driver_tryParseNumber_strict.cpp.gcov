        -:    0:Source:driver_tryParseNumber_strict.cpp
        -:    1:#include "hjson.h"
        -:    2:#include "../hjson-cpp/src/hjson_parsenumber.cpp"
        -:    3:#include <iostream>
        -:    4:#include <cstring>
        -:    5:using namespace Hjson;
        -:    6:
        1:    7:int main() {
        1:    8:    Value val;
        -:    9:    // 1. Valid integer
        1:   10:    tryParseNumber(&val, "42", 2, false);
        -:   11:    // 2. Valid negative integer
        1:   12:    tryParseNumber(&val, "-17", 3, false);
        -:   13:    // 3. Valid float with decimal
        1:   14:    tryParseNumber(&val, "3.14", 4, false);
        -:   15:    // 4. Valid float with exponent
        1:   16:    tryParseNumber(&val, "1e10", 4, false);
        -:   17:    // 5. Valid float with negative exponent
        1:   18:    tryParseNumber(&val, "2.5E-3", 6, false);
        -:   19:    // 6. Valid float with plus exponent
        1:   20:    tryParseNumber(&val, "9E+2", 4, false);
        -:   21:    // 7. Leading zeros (invalid)
        1:   22:    tryParseNumber(&val, "007", 3, false);
        -:   23:    // 8. Single zero (valid)
        1:   24:    tryParseNumber(&val, "0", 1, false);
        -:   25:    // 9. Trailing whitespace accepted
        1:   26:    tryParseNumber(&val, "123 ", 4, false);
        -:   27:    // 10. stopAtNext with comma
        1:   28:    tryParseNumber(&val, "456,", 4, true);
        -:   29:    // 11. stopAtNext with brace
        1:   30:    tryParseNumber(&val, "789}", 4, true);
        -:   31:    // 12. stopAtNext with bracket
        1:   32:    tryParseNumber(&val, "101]", 4, true);
        -:   33:    // 13. stopAtNext with hash comment
        1:   34:    tryParseNumber(&val, "202#", 4, true);
        -:   35:    // 14. stopAtNext with // comment
        1:   36:    tryParseNumber(&val, "303//", 5, true);
        -:   37:    // 15. stopAtNext with /* comment
        1:   38:    tryParseNumber(&val, "404/*", 5, true);
        -:   39:    // 16. Invalid character after number
        1:   40:    tryParseNumber(&val, "505x", 4, false);
        -:   41:    // 17. Negative zero (valid)
        1:   42:    tryParseNumber(&val, "-0", 2, false);
        -:   43:    // 18. Float starting with dot (should be invalid by _parseFloat)
        1:   44:    tryParseNumber(&val, ".5", 2, false);
        -:   45:    // 19. Empty string
        1:   46:    tryParseNumber(&val, "", 0, false);
        -:   47:    // 20. Just a minus sign
        1:   48:    tryParseNumber(&val, "-", 1, false);
        -:   49:    // 21. Number with leading zeros and decimal
        1:   50:    tryParseNumber(&val, "00.5", 4, false);
        -:   51:    // 22. stopAtNext without matching punctuator
        1:   52:    tryParseNumber(&val, "99:", 3, true);
        -:   53:    // 23. Valid number at exact end of buffer
        1:   54:    tryParseNumber(&val, "7", 1, false);
        -:   55:    // 24. Exponent with no digits after
        1:   56:    tryParseNumber(&val, "5e", 2, false);
        -:   57:    // 25. Exponent sign with no digits after
        1:   58:    tryParseNumber(&val, "5e-", 3, false);
        -:   59:    // 26. Valid number with trailing newline
        1:   60:    tryParseNumber(&val, "88\n", 3, false);
        1:   61:    return 0;
        1:   62:}
